<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#37474F"
        android:gravity="center"
        android:orientation="vertical">

        <View
            android:layout_width="120dp"
            android:layout_height="3dp"
            android:background="#00E5A8" />

        <TextView
            android:id="@+id/txtCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="660"
            android:textColor="#00E5A8"
            android:textSize="48sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="mA"
            android:textColor="#00E5A8"
            android:textSize="22sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="min: 580 mA"
                android:textColor="#00E5A8" />

            <TextView
                android:id="@+id/txtMax"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="max: 660 mA"
                android:textColor="#00E5A8" />

        </LinearLayout>

    </LinearLayout>

    <!-- Battery icon -->
    <ImageView
        android:id="@+id/imgBattery"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="start"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_lock_idle_charging" />

    <!-- Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtStatus"
            android:text="Status: Charging"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtLevel"
            android:text="Level: 46%"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtHealth"
            android:text="Health: Good"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtVoltage"
            android:text="Voltage: 4100 mV"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtTemp"
            android:text="Temperature: 31.7 °C"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtTech"
            android:text="Technology: Li-ion"
            android:textColor="#00BFA5"
            android:textSize="16sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/txtAvgCurrent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00E5A8"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtCapacity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00BFA5"
            android:textSize="16sp"/>

        <TextView
            android:id="@+id/txtChargeCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#00BFA5"
            android:textSize="16sp"/>

    </LinearLayout>

</LinearLayout>